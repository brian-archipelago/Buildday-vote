# Required: Anthropic API key (Claude) for pitch summarization
ANTHROPIC_API_KEY=sk-ant-...

# Admin access token. Anyone with this can control the poll.
ADMIN_TOKEN=change-me-before-the-event

# Optional: override the public base URL used in the QR code on /display
# (defaults to the request's own origin)
# NEXT_PUBLIC_BASE_URL=https://vote.example.com
